# ═══════════════════════════════════════════════════════════════
#  Android / Android Studio / Gradle — .gitignore
# ═══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
# Gradle
# ──────────────────────────────────────────────────────────────
.gradle/
gradle-app.setting
!gradle-wrapper.jar
!gradle-wrapper.properties
build/
**/build/

# ──────────────────────────────────────────────────────────────
# Android Studio / IntelliJ
# ──────────────────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.navigation/
captures/
.externalNativeBuild/
.cxx/

# ──────────────────────────────────────────────────────────────
# Local configuration (berisi sdk.dir dll)
# ──────────────────────────────────────────────────────────────
local.properties

# ──────────────────────────────────────────────────────────────
# Keystore / Signing (RAHASIA)
# ──────────────────────────────────────────────────────────────
*.jks
*.keystore
*.pepk
keystore.properties
signing.properties
release.properties

# ──────────────────────────────────────────────────────────────
# Generated Files
# ──────────────────────────────────────────────────────────────
**/generated/
app/src/main/java/**/BuildConfig.java
app/src/debug/
app/src/release/

# ──────────────────────────────────────────────────────────────
# APK / Bundle Output
# ──────────────────────────────────────────────────────────────
*.apk
*.aab
*.ap_
*.dex

# ──────────────────────────────────────────────────────────────
# Proguard / R8
# ──────────────────────────────────────────────────────────────
proguard/
*.pro.bak

# ──────────────────────────────────────────────────────────────
# NDK / CMake
# ──────────────────────────────────────────────────────────────
*.so
*.o

# ──────────────────────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────────────────────
*.log
logs/

# ──────────────────────────────────────────────────────────────
# Heap Dump (penyebab error GitHub >100MB)
# ──────────────────────────────────────────────────────────────
*.hprof

# ──────────────────────────────────────────────────────────────
# Test & Coverage
# ──────────────────────────────────────────────────────────────
**/test-results/
**/coverage/
*.exec

# ──────────────────────────────────────────────────────────────
# Environment File
# ──────────────────────────────────────────────────────────────
.env

# ──────────────────────────────────────────────────────────────
# OS Files
# ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini